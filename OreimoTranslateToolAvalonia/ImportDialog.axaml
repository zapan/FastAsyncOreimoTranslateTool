<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OreimoTranslateToolAvalonia.ImportDialog"
        Title="Import"
        Width="280" Height="140"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="12" Spacing="8">

        <TextBlock Text="In each table, the translated text starts with:"/>

        <Grid ColumnDefinitions="60,*" RowDefinitions="Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Column:"
                       VerticalAlignment="Center"/>
            <NumericUpDown Grid.Row="0" Grid.Column="1"
                           x:Name="inputColumn"
                           Minimum="1" Value="3"
                           FormatString="0"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Cell:"
                       VerticalAlignment="Center" Margin="0,6,0,0"/>
            <NumericUpDown Grid.Row="1" Grid.Column="1"
                           x:Name="inputCell"
                           Minimum="1" Value="1"
                           Margin="0,6,0,0"
                           FormatString="0"/>
        </Grid>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Content="OK"     MinWidth="72" Click="ButtonOk_Click"/>
            <Button Content="Cancel" MinWidth="72" Click="ButtonCancel_Click"/>
        </StackPanel>

    </StackPanel>

</Window>
