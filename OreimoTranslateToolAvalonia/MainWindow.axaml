<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OreimoTranslateToolAvalonia.MainWindow"
        Title="Toradora &amp; Oreimo Translate Tool"
        Width="650" Height="410"
        MinWidth="650" MinHeight="410"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Button.action">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="46"/>
        </Style>
        <Style Selector="Button.help">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="*,250" RowDefinitions="*,Auto">

        <!-- Left: cat image -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                BorderBrush="#CCCCCC" BorderThickness="1"
                Margin="10,10,5,10">
            <Image x:Name="catImage" Source="" Stretch="Uniform"/>
        </Border>

        <!-- Right: control panel -->
        <Border Grid.Column="1" Grid.Row="0"
                BorderBrush="#CCCCCC" BorderThickness="1"
                Margin="5,10,10,-15">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">

                <!-- Status label -->
                <TextBlock Grid.Row="0"
                           x:Name="labelWork"
                           Text="Ready"
                           FontSize="24"
                           FontWeight="DemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,10"/>

                <!-- Extract ISO row -->
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="8,4,8,4">
                    <Button Grid.Column="0" x:Name="buttonExtractIso"
                            Classes="action"
                            Content="Extract ISO"
                            VerticalContentAlignment="Center"
                            IsVisible="True"
                            Click="ButtonExtractIso_Click"/>
                    <Button Grid.Column="1" 
                            x:Name="ExtractIsoHelpButton"
                            Classes="help"
                            Content="?" Margin="4,0,0,0"
                            Click="ButtonExtractIsoHelp_Click"/>
                </Grid>

                <!-- IsoProgress (hidden by default, replaces button while working) -->
                <ProgressBar Grid.Row="1"
                             x:Name="IsoProgress"
                             Minimum="0" Maximum="100" Value="0"
                             Height="46" Margin="8,4,42,4"
                             IsVisible="False"/>

                <!-- Extract game files row -->
                <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="8,4,8,4">
                    <Button Grid.Column="0" x:Name="buttonExtractGame"
                            Classes="action"
                            Content="Extract game files"
                            VerticalContentAlignment="Center"
                            IsEnabled="False"
                            Click="ButtonExtractGame_Click"/>
                    <Button Grid.Column="1" Classes="help"
                            Content="?" Margin="4,0,0,0"
                            Click="ButtonExtractGameHelp_Click"/>
                </Grid>

                <!-- Delete generated resources (hidden by default, overlays extract game button) -->
                <Button Grid.Row="2"
                        x:Name="buttonDeleteGenRes"
                        Classes="action"
                        Foreground="Red"
                        Content="Delete generated resources"
                        VerticalContentAlignment="Center"
                        Margin="8,4,42,4"
                        IsVisible="False"
                        Click="ButtonDeleteGenRes_Click"/>

                <!-- Translate strings row -->
                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="8,4,8,4">
                    <Button Grid.Column="0" x:Name="buttonTranslate"
                            Classes="action"
                            Content="Translate strings"
                            VerticalContentAlignment="Center"
                            IsEnabled="False"
                            Click="ButtonTranslate_Click"/>
                    <Button Grid.Column="1" Classes="help"
                            Content="?" Margin="4,0,0,0"
                            Click="ButtonTranslateHelp_Click"/>
                </Grid>

                <!-- Repack game files row -->
                <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="8,4,8,4">
                    <Button Grid.Column="0" x:Name="buttonRepackGame"
                            Classes="action"
                            Content="Repack game files"
                            VerticalContentAlignment="Center"
                            IsEnabled="False"
                            Click="ButtonRepackGame_Click"
                            ContextMenu="{StaticResource RepackContextMenu}"/>
                    <Button Grid.Column="1" Classes="help"
                            Content="?" Margin="4,0,0,0"
                            Click="ButtonRepackGameHelp_Click"/>
                </Grid>

                <!-- Start game row -->
                <Grid Grid.Row="5" ColumnDefinitions="*,Auto" Margin="8,4,8,4">
                    <Button Grid.Column="0" x:Name="buttonStartGame"
                            Classes="action"
                            Content="Start game"
                            VerticalContentAlignment="Center"
                            IsEnabled="False"
                            Click="ButtonStartGame_Click"/>
                    <Button Grid.Column="1" Classes="help"
                            Content="?" Margin="4,0,0,0"
                            Click="ButtonStartGameHelp_Click"/>
                </Grid>

                <!-- Export game row -->
                <Grid Grid.Row="6" ColumnDefinitions="*,Auto" Margin="8,4,8,4">
                    <Button Grid.Column="0" x:Name="buttonExportGame"
                            Classes="action"
                            Content="Export game"
                            VerticalContentAlignment="Center"
                            IsEnabled="False"
                            Click="ButtonExportGame_Click"/>
                    <Button Grid.Column="1" 
                            x:Name="ExportGameHelpButton"
                            Classes="help"
                            Content="?" Margin="4,0,0,0"
                            Click="ButtonRepackIsoHelp_Click"/>
                </Grid>

                <!-- Export progress (hidden by default) -->
                <ProgressBar Grid.Row="6"
                             x:Name="ExtractProgress"
                             Minimum="0" Maximum="100" Value="0"
                             Height="46" Margin="8,4,42,4"
                             IsVisible="False"/>

            </Grid>
        </Border>

        <!-- Version label bottom-left -->
        <TextBlock Grid.Column="0" Grid.Row="1"
                   x:Name="labelVersion"
                   Text="X.X.X"
                   Foreground="#AAAAAA"
                   FontSize="11"
                   Margin="14,2,0,10"
                   VerticalAlignment="Bottom"/>

    </Grid>

    <Window.Resources>
        <ContextMenu x:Key="RepackContextMenu">
            <MenuItem x:Name="itemDebugMode"
                      Header="Debug mode"
                      ToggleType="CheckBox"/>
        </ContextMenu>
    </Window.Resources>

</Window>
